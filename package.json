{
    "name":  "merlin-api",
    "version":  "1.1.8",
    "private":  true,
    "scripts":  {
                    "deploy":  "wrangler deploy",
                    "dev":  "wrangler dev",
                    "start":  "wrangler dev",
                    "typecheck":  "tsc --noEmit",
                    "types":  "wrangler types",
                    "cf-typegen":  "wrangler types",
                    "admin:bootstrap":  "node scripts/bootstrap-admin.mjs",
                    "build:panel":  "npm --prefix ../merlin-admin run build",
                    "d1:migrate:remote":  "wrangler d1 migrations apply merlin-db --remote",
                    "deploy:panel":  "npm run build:panel \u0026\u0026 npm run types \u0026\u0026 npm run deploy"
                },
    "dependencies":  {
                         "chanfana":  "^3.3.0",
                         "hono":  "^4.12.12",
                         "zod":  "^4.3.6"
                     },
    "devDependencies":  {
                            "@types/node":  "^25.9.4",
                            "typescript":  "^6.0.3",
                            "wrangler":  "^4.103.0"
                        }
}
